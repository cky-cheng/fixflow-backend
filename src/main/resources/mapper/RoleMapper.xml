<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kory.fixflow.role.mapper.RoleMapper">

    <!-- 根据用户ID 查询角色编码列表 -->
    <select id="selectRoleCodesByUserId"
            parameterType="java.lang.Long"
            resultType="java.lang.String">
        SELECT
        r.role_code
        FROM user_role ur
        INNER JOIN role r
        ON ur.role_id = r.id
        WHERE ur.user_id = #{userId}
        AND r.is_deleted = 0
        AND r.status = 1
    </select>

    <!-- 查询所有启用角色 -->
    <select id="selectEnableRoles"
            resultType="com.kory.fixflow.role.vo.RoleVO">
        SELECT
        id,
        role_name,
        role_code,
        description
        FROM role
        WHERE is_deleted = 0
        AND status = 1
        ORDER BY id ASC
    </select>


    <!-- 根据角色ID列表查询启用角色-->
    <select id="selectEnabledRolesById"
            resultType="com.kory.fixflow.role.entity.Role">
        SELECT
        id,
        role_name,
        role_code,
        description,
        status,
        is_deleted,
        create_time,
        update_time
        FROM role
        WHERE is_deleted = 0
        AND status = 1
        AND id IN
        <foreach collection="list" item="roleId" open="(" separator="," close=")">
            #{roleId}
        </foreach>
    </select>


</mapper>